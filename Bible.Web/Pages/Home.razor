@page "/"
@using Bible.Core.Models
@using System.Diagnostics.CodeAnalysis
@inject IDataService<IEnumerable<BibleBook>> DataService

<PageTitle>Bible</PageTitle>

<BookChapter BookName="@bookName" ChapterNumber="@chapterNumber" />

@code {
    [CascadingParameter]
    public string? SearchText { get; set; } //= "John 1";

    string? bookName;
    int chapterNumber = 1;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        GetBookAndChapter();
    }

    void GetBookAndChapter()
    {
        var chars = new char[] { ' ', '_', '-', ':', ';' };
        var words = SearchText?.Split(chars);
        if (words?.Length > 0)
        {
            if (!char.IsDigit(words[0][0]))
            {
                bookName = words[0];
                if (words.Length > 1 && int.TryParse(words[1], out int chapter))
                {
                    chapterNumber = chapter;
                }
            }
            else if (words.Length > 1)
            {
                bookName = string.Join(' ', words[0], words[1]);
                if (words.Length > 2 && int.TryParse(words[2], out int chapter))
                {
                    chapterNumber = chapter;
                }
            }
            else
            {
                bookName = SearchText;
            }
        }
    }
}